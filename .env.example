# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WHATSAPP_TOKEN: Permanent access token from Meta Developer App
WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID: ID of the phone number in Meta App
WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN: Random string for webhook verification
WHATSAPP_VERIFY_TOKEN=

# STRIPE_SECRET_KEY: Secret key from Stripe Dashboard
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET: Secret for verifying Stripe webhooks
STRIPE_WEBHOOK_SECRET=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
